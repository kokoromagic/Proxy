{
  "manifest_version": 3,
  "name": "Dynamic Proxy Connector",
  "version": "2.1",
  "permissions": [
    "proxy",
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://kokoromagic.github.io/*",
    "https://api.ipify.org/*",
    "http://connectivitycheck.gstatic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}